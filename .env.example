# Database Configuration
# For SQLite (default for development):
DATABASE_URL="file:./prisma/dev.db"

# For PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@localhost:5432/bom_app"

# For MySQL:
# DATABASE_URL="mysql://user:password@localhost:3306/bom_app"

# Application
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3000"
APP_BASE_URL="http://localhost:3000"
DEFAULT_USER_ROLE="engineering"

# Integrations
WORK_ORDER_API_BASE_URL=""
WORK_ORDER_API_KEY=""
INVENTORY_API_BASE_URL=""
INVENTORY_API_KEY=""
PROCUREMENT_API_BASE_URL=""
PROCUREMENT_API_KEY=""
INTEGRATION_TIMEOUT_MS="4000"
WORK_ORDER_FALLBACK_JSON=""

# Notification
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""
APPROVER_EMAILS=""
OWNER_EMAILS=""

# Cron endpoint security
CRON_SECRET=""

